
@{
    ViewData["Title"] = "VistaPosLog";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="profile-container">
    <div class="profile-card">
        <div class="profile-header">
            <div class="avatar-circle">
                @Model.Nombre.Substring(0, 1).ToUpper()
            </div>
            <h2>Bienvenido, @Model.Nombre</h2>
            <p class="subtitle">Datos recuperados de la API</p>
        </div>

        <div class="profile-details">
            <div class="detail-item">
                <span class="label">Nombre Completo:</span>
                <span class="value">@Model.Nombre @Model.Apellido</span>
            </div>

            <div class="detail-item">
                <span class="label">Correo Electrónico:</span>
                <span class="value">@Model.Email</span>
            </div>

            <div class="detail-item">
                <span class="label">Identificación:</span>
                <span class="value">@Model.Identificacion</span>
            </div>

            <div class="detail-item">
                <span class="label">ID de Usuario:</span>
                <span class="value">#@Model.IdUsuario</span>
            </div>
        </div>

        <div class="profile-actions">
            <a href="/Home/Index" class="btn-secondary">Ir al Inicio</a>
        </div>
    </div>
</div>

