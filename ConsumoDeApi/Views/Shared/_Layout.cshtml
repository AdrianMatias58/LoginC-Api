
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Mi App</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Perfil.css" asp-append-version="true" />

</head>
<body>

    @if (Context.Session.GetString("Nombre") != null)
    {
        <nav class="navbar">
            <span>Bienvenido, @Context.Session.GetString("Nombre") @Context.Session.GetString("Apellido")</span>
            <a href="/Login/Logout">Cerrar sesión</a>
        </nav>
    }

    <div class="container">
        @RenderBody()
    </div>

</body>
</html>